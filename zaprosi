--отчет о продажам за день
SELECT DATE(payment_time) as day, 
       COUNT(*) as tickets_sold, 
       SUM(amount) as total_revenue
FROM payments
WHERE payment_time BETWEEN '2024-06-01' AND '2024-06-30'
GROUP BY DATE(payment_time)
ORDER BY day;

--самые популярные фильмы *_*
SELECT m.title, COUNT(t.id) as tickets_sold
FROM tickets t
JOIN sessions s ON t.session_id = s.id
JOIN movies m ON s.movie_id = m.id
WHERE t.status = 'purchased'
GROUP BY m.title
ORDER BY tickets_sold DESC
LIMIT 5;
