--юзер и билетик
SELECT m.title, s.session_time, t.seat_number, p.amount
FROM tickets t
JOIN sessions s ON t.session_id = s.id
JOIN movies m ON s.movie_id = m.id
LEFT JOIN payments p ON p.ticket_id = t.id
WHERE t.user_id = 1;

